---
import { site } from "../data/site";

const year = new Date().getFullYear();
---

<footer>
  <div class="container footer-inner">
    <p>© {year} {site.name}</p>
    <ul>
      <li><a href={`mailto:${site.email}`}>Email</a></li>
      <li>
        <a href={site.linkedin.url} target="_blank" rel="noopener">LinkedIn</a>
      </li>
      <li>
        <a href={site.blog.url} target="_blank" rel="noopener">Blog</a>
      </li>
    </ul>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    margin-top: 4rem;
    padding: 1.5rem 0;
  }

  .footer-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  ul {
    display: flex;
    gap: 1.25rem;
    list-style: none;
  }

  a {
    color: var(--text-muted);
  }

  a:hover {
    color: var(--accent);
  }
</style>
