---
import BaseLayout from "../layouts/BaseLayout.astro";
import ReferencesGrid from "../components/ReferencesGrid.astro";
import { site } from "../data/site";
---

<BaseLayout
  title={`References | ${site.name}`}
  description={`Recommendations and references for ${site.name}.`}
>
  <div class="container">
    <h1 class="section-title">References</h1>
    <ReferencesGrid />
  </div>
</BaseLayout>

<style>
  .container {
    padding-top: 3rem;
  }

  .section-title {
    margin-bottom: 2rem;
  }
</style>
